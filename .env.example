# Required
DISCORD_TOKEN=your-bot-token-here

# Optional: restrict bot to a single server
# GUILD_ID=your-guild-id-here

# Game settings (defaults shown)
# MIN_LEVEL=6
# MAX_LEVEL=12
# DARK_MIN_LEVEL=7
# MAX_PLAYERS=4
# DARK_MAX_PLAYERS=3

# Timing
# MIN_LEAD_MINUTES=5
# MAX_LEAD_HOURS=8
# REMINDER_MINUTES=5,1
# ROUND_MINUTES=5

# Roles
# ROLE_PREFIX=RS
